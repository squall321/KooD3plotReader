Bootstrap: docker
From: ubuntu:22.04

%labels
    Author       KooD3plotReader Team
    Version      2.4.0
    Description  LS-DYNA d3plot post-processing toolchain (headless, Slurm-ready) — DROP/IMPACT 통합

%help
    KooD3plotReader — Headless post-processing module.

    Bundled tools (PATH):
      unified_analyzer     — C++ d3plot analysis engine
      koo_deep_report      — Python single-sim report (HTML)
      koo_sphere_report    — Python all-angle sphere report (DROP cumulative)
      koo_impact_report    — Python multi-position partial-impact DOE report (IMPACT cumulative)
      post_analyze         — Bash orchestrator (unified → sphere|impact → deep, auto-detect by scenario.json)

    Usage:
      apptainer exec SmartTwinPostprocessor.sif unified_analyzer --help
      apptainer exec SmartTwinPostprocessor.sif post_analyze <test_dir>
      apptainer exec SmartTwinPostprocessor.sif koo_deep_report <d3plot_dir>

    With data bind:
      apptainer exec --bind /data:/data SmartTwinPostprocessor.sif \
          post_analyze /data/test_001 --section-view --section-view-backend lsprepost

    Headless rendering:
      - software backend (CPU, no GPU/display needed — recommended for headless):
          ... --section-view --section-view-backend software
      - lsprepost backend, GPU-accelerated (NVIDIA, VirtualGL):
          apptainer exec --nv --bind /data:/data SmartTwinPostprocessor.sif \
            env KOOD3PLOT_GPU_RENDER=1 post_analyze /data/test_001 \
            --section-view --section-view-backend lsprepost
        (requires --nv to bind the host NVIDIA driver; KOOD3PLOT_GPU_RENDER=1
         routes LSPrePost through `vglrun -d egl` + the non-mesa wrapper.
         Without --nv or the env, it falls back to software mesa GL.)

    Build:
      apptainer build SmartTwinPostprocessor.sif SmartTwinPostprocessor.def

%files
    # LSPrePost 바이너리 (호스트 installed/lsprepost/ → 컨테이너 /opt/_lsprepost_staging/)
    ../installed/lsprepost /opt/_lsprepost_staging

%post
    set -e

    # System dependencies
    apt-get update
    # 빌드 필수 패키지 (하나라도 빠지면 빌드 실패해야 하는 것들)
    apt-get install -y --no-install-recommends \
        build-essential cmake g++ git ca-certificates pkg-config wget \
        libomp-dev python3 python3-pip python3-venv \
        ffmpeg libpng-dev xvfb \
        libgl1 libglu1-mesa libxrandr2 libxi6 libxcursor1 \
        libxinerama1 libxkbcommon0

    # --- GPU 렌더(VirtualGL) — best-effort, 실패해도 빌드 안 죽음 ---
    # GLX 전용 LSPrePost 를 헤드리스 GPU 로 가속하는 경로(KOOD3PLOT_GPU_RENDER=1
    # + apptainer --nv 일 때만 사용). virtualgl 은 Ubuntu 기본 repo 에 없어
    # GitHub 릴리스 .deb 로 설치. EGL 런타임(libglvnd/libegl)은 vglrun 의 EGL
    # 백엔드용 — 패키지명이 배포본마다 달라 개별 설치 후 실패는 무시.
    # 모두 실패해도 SW/mesa 렌더 경로는 정상 동작하므로 빌드는 계속 진행.
    for p in libegl1 libegl-mesa0 libgles2 libglvnd0 libgl1-mesa-dri; do
        apt-get install -y --no-install-recommends "$p" 2>/dev/null \
            || echo "WARN: optional GPU pkg '$p' 설치 실패 (skip)"
    done
    VGL_DEB=/tmp/virtualgl.deb
    if wget -q -O "$VGL_DEB" \
         "https://github.com/VirtualGL/virtualgl/releases/download/3.1.1/virtualgl_3.1.1_amd64.deb"; then
        apt-get install -y --no-install-recommends "$VGL_DEB" \
            || echo "WARN: VirtualGL .deb 설치 실패 — GPU 렌더 비활성(SW/mesa 정상)"
    else
        echo "WARN: VirtualGL .deb 다운로드 실패 — GPU 렌더 비활성(SW/mesa 정상)"
    fi
    rm -f "$VGL_DEB"

    # Clone source and build
    cd /opt
    git clone --depth 1 https://github.com/squall321/KooD3plotReader.git
    cd KooD3plotReader

    # Build module (headless: no viewer, no Nuitka to keep size small).
    # --section-render: 자체 SW 섹션렌더(CPU, GTK/GPU/디스플레이 불요) 강제 ON.
    # 자동감지 의존 제거 — 과거 빌드에서 OFF 로 떨어져 "software renderer not
    # available" stub 가 출고되던 회귀 방지.
    ./scripts/build_module.sh --prefix /opt/kood3plot --no-viewer --section-render

    # LSPrePost: %files 에서 staging 으로 복사된 것을 최종 위치로 이동
    if [ -d /opt/_lsprepost_staging ]; then
        mkdir -p /opt/kood3plot/lsprepost
        cp -r /opt/_lsprepost_staging/* /opt/kood3plot/lsprepost/
        chmod +x /opt/kood3plot/lsprepost/lsprepost 2>/dev/null || true
        sed -i 's/^LSPrePost:.*/LSPrePost:  bundled/' /opt/kood3plot/VERSION 2>/dev/null || true
        rm -rf /opt/_lsprepost_staging
        echo "LSPrePost bundled → /opt/kood3plot/lsprepost/"
    fi

    # Cleanup: remove build artifacts and source (keep only /opt/kood3plot)
    rm -rf /opt/KooD3plotReader/build
    rm -rf /opt/KooD3plotReader/.git

    # Install runtime Python deps (for non-Nuitka wrapper mode)
    pip install --no-cache-dir rich pyyaml

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export KOOD3PLOT_HOME=/opt/kood3plot
    export PATH=/opt/kood3plot/bin:$PATH
    export PYTHONPATH=/opt/kood3plot/python/koo_deep_report:/opt/kood3plot/python/koo_sphere_report:/opt/kood3plot/python/koo_impact_report
    export LSPREPOST_PATH=/opt/kood3plot/lsprepost
    export OMP_NUM_THREADS=${SLURM_CPUS_PER_TASK:-4}
    # VirtualGL EGL 백엔드 기본 GPU 디바이스(헤드리스). KOOD3PLOT_GPU_RENDER=1
    # 일 때만 vglrun 이 사용. GPU 모드 OFF 면 무영향.
    export VGL_DISPLAY=egl

%runscript
    if [ $# -eq 0 ]; then
        cat /opt/kood3plot/VERSION
        echo ""
        echo "Usage: apptainer exec SmartTwinPostprocessor.sif <command> [args]"
        echo "Commands: unified_analyzer, koo_deep_report, koo_sphere_report, koo_impact_report, post_analyze"
        exit 0
    fi
    exec "$@"

%test
    /opt/kood3plot/bin/unified_analyzer --help >/dev/null
    /opt/kood3plot/bin/koo_deep_report --help >/dev/null
    /opt/kood3plot/bin/koo_sphere_report --help >/dev/null
    /opt/kood3plot/bin/koo_impact_report --help >/dev/null
    echo "All tools available"
