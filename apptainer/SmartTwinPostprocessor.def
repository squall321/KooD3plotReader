Bootstrap: docker
From: ubuntu:22.04

%labels
    Author       KooD3plotReader Team
    Version      2.3.1
    Description  LS-DYNA d3plot post-processing toolchain (headless, Slurm-ready)

%help
    KooD3plotReader — Headless post-processing module.

    Bundled tools (PATH):
      unified_analyzer     — C++ d3plot analysis engine
      koo_deep_report      — Python single-sim report (HTML)
      koo_sphere_report    — Python all-angle sphere report
      post_analyze         — Bash orchestrator (unified → deep → sphere)

    Usage:
      apptainer exec SmartTwinPostprocessor.sif unified_analyzer --help
      apptainer exec SmartTwinPostprocessor.sif post_analyze <test_dir>
      apptainer exec SmartTwinPostprocessor.sif koo_deep_report <d3plot_dir>

    With data bind:
      apptainer exec --bind /data:/data SmartTwinPostprocessor.sif \
          post_analyze /data/test_001 --section-view --section-view-backend lsprepost

    Build:
      apptainer build SmartTwinPostprocessor.sif SmartTwinPostprocessor.def

%post
    set -e

    # System dependencies
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential cmake g++ git ca-certificates \
        libomp-dev python3 python3-pip python3-venv \
        ffmpeg libpng-dev xvfb \
        libgl1 libglu1-mesa libxrandr2 libxi6 libxcursor1 \
        libxinerama1 libxkbcommon0

    # Clone source and build
    cd /opt
    git clone --depth 1 https://github.com/squall321/KooD3plotReader.git
    cd KooD3plotReader

    # Build module (headless: no viewer, no Nuitka to keep size small)
    ./scripts/build_module.sh --prefix /opt/kood3plot --no-viewer

    # Copy bundled LSPrePost if present (build_module.sh auto-bundles)
    # No action needed — build_module.sh handles it

    # Cleanup: remove build artifacts and source (keep only /opt/kood3plot)
    rm -rf /opt/KooD3plotReader/build
    rm -rf /opt/KooD3plotReader/.git

    # Install runtime Python deps (for non-Nuitka wrapper mode)
    pip install --no-cache-dir rich pyyaml

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export KOOD3PLOT_HOME=/opt/kood3plot
    export PATH=/opt/kood3plot/bin:$PATH
    export PYTHONPATH=/opt/kood3plot/python/koo_deep_report:/opt/kood3plot/python/koo_sphere_report
    export LSPREPOST_PATH=/opt/kood3plot/lsprepost
    export OMP_NUM_THREADS=${SLURM_CPUS_PER_TASK:-4}

%runscript
    if [ $# -eq 0 ]; then
        cat /opt/kood3plot/VERSION
        echo ""
        echo "Usage: apptainer exec SmartTwinPostprocessor.sif <command> [args]"
        echo "Commands: unified_analyzer, koo_deep_report, koo_sphere_report, post_analyze"
        exit 0
    fi
    exec "$@"

%test
    /opt/kood3plot/bin/unified_analyzer --help >/dev/null
    /opt/kood3plot/bin/koo_deep_report --help >/dev/null
    /opt/kood3plot/bin/koo_sphere_report --help >/dev/null
    echo "All tools available"
